# Instagram Graph API (Professional/Business 계정)
# https://developers.facebook.com/docs/instagram-api

# Meta 앱 ID — 앱 설정 → 기본 → **앱 ID** (숫자)
# ⚠️ Instagram API 설정 화면의 계정 ID와 다름!
IG_APP_ID=

# Instagram 계정 ID — API 설정 1단계 화면에 표시된 ID
IG_USER_ID=

# API 설정 1단계에서 생성한 액세스 토큰 (IG... 또는 EAA... 모두 가능)
IG_ACCESS_TOKEN=

# 하루 릴스 업로드 한도 (테스트: 1, 운영: 3)
IG_REELS_PER_DAY=1

# KST 게시 시간 (슬롯당 릴스 1회 시도)
IG_POST_TIMES=09:00,14:00,19:00
IG_TIMEZONE=Asia/Seoul

# output 경로 — devPulse 프로젝트 루트 기준 (어디서 실행해도 동일)
IG_OUTPUT_DIR=output
IG_SNS_DIR=output/sns
IG_STATE_DB=output/instagram/state.db

# 폴링 간격(초) — 노트북에서 하루 종일 실행
IG_POLL_SEC=60

# Graph API 버전
IG_GRAPH_VERSION=v21.0

# 공개 HTTPS URL — ./scripts/start-media-tunnel.sh (localhost:9088 터널)
IG_MEDIA_PORT=9088
MINIO_PUBLIC_ENDPOINT=

# (대안) 파일을 직접 HTTPS로 서빙하는 베이스 URL
IG_MEDIA_PUBLIC_BASE_URL=

# 1이면 실제 업로드 없이 로그만 (테스트 1단계: DRY_RUN=1 → ./scripts/test-instagram.sh)
# 확인 후 0으로 바꾸고 다시 실행
IG_DRY_RUN=1
