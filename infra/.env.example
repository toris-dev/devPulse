DATABASE_URL=postgresql://devpulse:devpulse@localhost:5434/devpulse
REDIS_URL=redis://localhost:6381/0
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=devpulse
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_PORT=1234
LLM_PROFILE=korean
# LM Studio에 표시된 model id (예: qwen3-8b)
LLM_MODEL=qwen3-8b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_CONTEXT_LENGTH=8192
QDRANT_URL=http://localhost:6333
SNS_MODE=file
SNS_OUTPUT_DIR=./output/sns
DURATION_HOURS=0
BATCH_SIZE=5
COLLECT_LIMIT=0
COLLECT_WORKERS=4
PROCESS_WORKERS=2
PROCESS_BATCH_MAX=10
IDLE_POLL_SEC=90
BACKLOG_PAUSE_SEC=0
FEEDS="all new ask show top"
BUNDLE_SIZE=6
BUNDLE_CARD_SECONDS=5
BUNDLE_ALLOW_PAD=1
BUNDLE_MIN_CARDS=1
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787
DASHBOARD_ENABLED=1
MASTODON_INSTANCE=
MASTODON_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

